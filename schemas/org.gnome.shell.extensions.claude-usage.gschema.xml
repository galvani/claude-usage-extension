<?xml version="1.0" encoding="UTF-8"?>
<schemalist>
  <schema id="org.gnome.shell.extensions.claude-usage"
          path="/org/gnome/shell/extensions/claude-usage/">

    <!-- Panel re-render cadence. Cheap (no network) — just advances the time
         marker and reset countdown. Network fetches are gated separately by
         usage-poll-interval. -->
    <key name="refresh-interval" type="i">
      <default>60</default>
      <range min="5" max="3600"/>
      <summary>Panel update interval (seconds)</summary>
      <description>How often the panel re-renders (advances the time marker and countdown). No network call.</description>
    </key>

    <!-- Minimum seconds between actual calls to Anthropic's usage endpoint.
         The endpoint throttles hard, so keep this comfortably high. Between
         fetches the last value is shown, with the time marker advancing. -->
    <key name="usage-poll-interval" type="i">
      <default>300</default>
      <range min="60" max="3600"/>
      <summary>Usage fetch interval (seconds)</summary>
      <description>Minimum time between calls to Anthropic's usage endpoint. The endpoint is aggressively rate-limited; do not set this too low.</description>
    </key>

    <!-- Thresholds are on PROJECTED end-of-window usage = current utilisation
         divided by the fraction of the 5-hour window elapsed. 100% means "on
         track to land exactly at the limit"; 150% means "on track for 1.5x".
         A fresh window (usage below the pace floor) always reads green. -->
    <key name="warn-threshold" type="i">
      <default>100</default>
      <range min="50" max="500"/>
      <summary>Warning pace (%)</summary>
      <description>At or above this projected end-of-window usage the bar turns amber.</description>
    </key>

    <key name="critical-threshold" type="i">
      <default>150</default>
      <range min="50" max="500"/>
      <summary>Critical pace (%)</summary>
      <description>At or above this projected end-of-window usage the bar turns red and the warning icon appears.</description>
    </key>

    <key name="show-percentage" type="b">
      <default>true</default>
      <summary>Show percentage label</summary>
      <description>Display the numeric percentage next to the bar.</description>
    </key>

    <key name="bar-width" type="i">
      <default>46</default>
      <range min="16" max="200"/>
      <summary>Bar width (px)</summary>
      <description>Width of the progress bar track in logical pixels.</description>
    </key>
  </schema>
</schemalist>
